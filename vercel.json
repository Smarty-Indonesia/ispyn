{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/about-us", "dest": "/api/about-us.php" },
    { "src": "/contact-us", "dest": "/api/contact-us.php" },
    { "src": "/kode-etik", "dest": "/api/kode-etik.php" },
    { "src": "/login-area", "dest": "/api/login-area" },
    { "src": "/marketing-plan", "dest": "/api/marketing-plan.php" },
    { "src": "/product", "dest": "/api/product.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
